# ──────────────────────────────────────────────────────────────────────────────
# Bayt Al Fann — Environment Variable Reference
# Copy this file to .env (or set these in your deployment platform).
# NEVER commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── API Server ────────────────────────────────────────────────────────────────

# Port for the Express API server
PORT=3001

# Node environment (development | production)
NODE_ENV=development

# JWT Secret — use a strong random string (min 32 chars)
# Generate one: openssl rand -hex 32
JWT_SECRET=replace-this-with-a-strong-random-secret-at-least-32-chars

# CORS: comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5174,https://yourdomain.com

# ── Database ──────────────────────────────────────────────────────────────────

# PostgreSQL connection string for Drizzle ORM
DATABASE_URL=postgresql://user:password@localhost:5432/bayt_al_fann

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
# Vite env vars MUST be prefixed with VITE_ to be exposed to the client bundle.

# Base URL of the API server (used by frontend API client)
VITE_API_BASE_URL=http://localhost:3001/api

# Admin portal credentials (client-side check — replace with server-side auth for production)
VITE_ADMIN_USER=your_admin_username
VITE_ADMIN_PASS=your_admin_password
